  Fridrich-1998               62.9 MB/s
  YeHuang-2018                 7.0 MB/s
  LSCM-2020                   10.2 MB/s

# Disable AES NI at runtime
 OPENSSL_ia32cap="~0x200000200000000" ./imgcrypt_bench 

