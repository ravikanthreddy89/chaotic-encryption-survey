Baseline

cd .. && rm -rf build && mkdir build && cd build
cmake .. -DYEH_USE_FAST_SIN=ON -DCHAOS_DIFFUSE_KERNEL=0 -DCHAOS_DIFFUSE_TILE_BYTES=16384
cmake --build . --target show_flags
make -j"$(nproc)"
./imgcrypt_bench

Results:
GEOMETRIC-MEAN THROUGHPUT (encrypt) ACROSS ALL IMAGES
  ??????????????????????????????????????????????????
